WHOICE_IMAGE_REGISTRY=ghcr.io/xmzo
# Optional: pin a release tag instead of following latest.
# WHOICE_IMAGE_TAG=0.01alpha

WHOICE_WEB_PORT=18081
WHOICE_WEB_BIND=0.0.0.0:18081
WHOICE_API_BIND=0.0.0.0:18080
WHOICE_API_ADDR=:8080
WHOICE_DATA_DIR=./data
WHOICE_LOOKUP_TIMEOUT=15s
WHOICE_PROVIDER_TIMEOUT=10s
WHOICE_AUTH_MODE=none
WHOICE_SITE_PASSWORD=
WHOICE_API_TOKENS=
WHOICE_TRUST_PROXY=false
WHOICE_METRICS_ENABLED=true
WHOICE_PSL_AUTO_UPDATE=false
WHOICE_PSL_URL=https://publicsuffix.org/list/public_suffix_list.dat
WHOICE_PSL_UPDATE_TIMEOUT=5s
WHOICE_RATE_LIMIT_ENABLED=false
WHOICE_RATE_LIMIT_ANON=60/min
WHOICE_RDAP_ENABLED=true
WHOICE_WHOIS_ENABLED=true
WHOICE_WHOIS_WEB_ENABLED=false
WHOICE_WHOIS_FOLLOW_LIMIT=1
WHOICE_ALLOW_CUSTOM_SERVERS=false
WHOICE_ALLOW_PRIVATE_SERVERS=false
WHOICE_ENRICH_EPP=true
WHOICE_ENRICH_BRANDS=false
WHOICE_ENRICH_REGISTRAR=true
WHOICE_ENRICH_DNS=true
WHOICE_DNS_TIMEOUT=3s
WHOICE_ENRICH_DNSVIZ=true
WHOICE_ENRICH_PRICING=false
WHOICE_ENRICH_MOZ=false
WHOICE_WEB_API_BASE=http://localhost:18080
