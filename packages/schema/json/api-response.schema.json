{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whoice.example/schema/api-response.schema.json",
  "title": "Whoice APIResponse",
  "type": "object",
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "result": { "$ref": "#/$defs/LookupResult" },
    "error": { "$ref": "#/$defs/APIError" },
    "capabilities": { "$ref": "#/$defs/Capabilities" },
    "meta": { "$ref": "#/$defs/ResultMeta" },
    "config": { "$ref": "#/$defs/ConfigStatus" }
  },
  "additionalProperties": false,
  "$defs": {
    "APIError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ICPResponse": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "result": { "$ref": "#/$defs/ICPResult" },
        "error": { "$ref": "#/$defs/APIError" },
        "meta": { "$ref": "#/$defs/ResultMeta" },
        "config": { "$ref": "#/$defs/ConfigStatus" }
      },
      "additionalProperties": false
    },
    "ConfigStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string" },
        "path": { "type": "string" },
        "loadedAt": { "type": "string" },
        "lastCheckedAt": { "type": "string" },
        "lastAttemptAt": { "type": "string" },
        "lastErrorAt": { "type": "string" },
        "lastError": { "type": "string" },
        "rolledBack": { "type": "boolean" },
        "usingLoadedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ConfigEditorStatus": {
      "type": "object",
      "required": ["status", "format", "writable", "sourceReadable", "surfaces", "supportedOperations"],
      "properties": {
        "status": { "type": "string" },
        "path": { "type": "string" },
        "format": { "type": "string" },
        "writable": { "type": "boolean" },
        "sourceReadable": { "type": "boolean" },
        "surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supportedOperations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ICPResult": {
      "type": "object",
      "required": ["domain", "status", "cached"],
      "properties": {
        "domain": { "type": "string" },
        "status": { "enum": ["found", "not_found", "error"] },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/ICPRecord" }
        },
        "source": { "type": "string" },
        "cached": { "type": "boolean" },
        "cachedAt": { "type": "string" },
        "expiresAt": { "type": "string" },
        "elapsedMs": { "type": "integer" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ICPRecord": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "domainId": { "type": "integer" },
        "unitName": { "type": "string" },
        "natureName": { "type": "string" },
        "mainLicence": { "type": "string" },
        "serviceLicence": { "type": "string" },
        "serviceName": { "type": "string" },
        "contentTypeName": { "type": "string" },
        "limitAccess": { "type": "string" },
        "updateRecordTime": { "type": "string" }
      },
      "additionalProperties": false
    },
    "LookupResult": {
      "type": "object",
      "required": [
        "query",
        "normalizedQuery",
        "type",
        "status",
        "source",
        "domain",
        "registry",
        "registrar",
        "dates",
        "statuses",
        "nameservers",
        "dnssec",
        "registrant",
        "network",
        "enrichment",
        "raw",
        "meta"
      ],
      "properties": {
        "query": { "type": "string" },
        "normalizedQuery": { "type": "string" },
        "type": { "enum": ["domain", "ipv4", "ipv6", "asn", "cidr", "url", "unknown"] },
        "status": { "enum": ["registered", "unregistered", "reserved", "unknown", "error"] },
        "source": { "$ref": "#/$defs/SourceInfo" },
        "domain": { "$ref": "#/$defs/DomainInfo" },
        "registry": { "$ref": "#/$defs/RegistryInfo" },
        "registrar": { "$ref": "#/$defs/RegistrarInfo" },
        "dates": { "$ref": "#/$defs/DateInfo" },
        "statuses": {
          "type": "array",
          "items": { "$ref": "#/$defs/DomainStatus" }
        },
        "nameservers": {
          "type": "array",
          "items": { "$ref": "#/$defs/Nameserver" }
        },
        "dnssec": { "$ref": "#/$defs/DNSSECInfo" },
        "registrant": { "$ref": "#/$defs/RegistrantInfo" },
        "network": { "$ref": "#/$defs/NetworkInfo" },
        "enrichment": {
          "type": "object",
          "properties": {
            "dns": { "$ref": "#/$defs/DNSInfo" },
            "dnsviz": { "$ref": "#/$defs/DNSVizInfo" },
            "pricing": { "$ref": "#/$defs/PricingInfo" },
            "moz": { "$ref": "#/$defs/MozInfo" }
          },
          "additionalProperties": true
        },
        "raw": { "$ref": "#/$defs/RawData" },
        "meta": { "$ref": "#/$defs/ResultMeta" }
      },
      "additionalProperties": false
    },
    "SourceInfo": {
      "type": "object",
      "required": ["used"],
      "properties": {
        "primary": { "enum": ["rdap", "whois", "whoisWeb"] },
        "used": {
          "type": "array",
          "items": { "enum": ["rdap", "whois", "whoisWeb"] }
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceError" }
        }
      },
      "additionalProperties": false
    },
    "SourceError": {
      "type": "object",
      "required": ["source", "error"],
      "properties": {
        "source": { "enum": ["rdap", "whois", "whoisWeb"] },
        "server": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DomainInfo": {
      "type": "object",
      "required": ["reserved", "registered"],
      "properties": {
        "name": { "type": "string" },
        "unicodeName": { "type": "string" },
        "punycodeName": { "type": "string" },
        "suffix": { "type": "string" },
        "registeredDomain": { "type": "string" },
        "reserved": { "type": "boolean" },
        "registered": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "RegistryInfo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "website": { "type": "string" },
        "whoisServer": { "type": "string" },
        "rdapServer": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DateInfo": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "expiresAt": { "type": "string" },
        "availableAt": { "type": "string" },
        "ageDays": { "type": "integer" },
        "remainingDays": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "RegistrarInfo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "ianaId": { "type": "string" },
        "country": { "type": "string" },
        "whoisServer": { "type": "string" },
        "rdapServer": { "type": "string" },
        "brand": { "$ref": "#/$defs/Brand" },
        "source": { "type": "string" },
        "confidence": { "type": "number" },
        "evidence": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DomainStatus": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": { "type": "string" },
        "label": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Nameserver": {
      "type": "object",
      "required": ["host"],
      "properties": {
        "host": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "brand": { "$ref": "#/$defs/Brand" }
      },
      "additionalProperties": false
    },
    "Brand": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "color": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DNSSECInfo": {
      "type": "object",
      "properties": {
        "signed": { "type": "boolean" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RegistrantInfo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "organization": { "type": "string" },
        "country": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "postalCode": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "extra": {
          "type": "array",
          "items": { "$ref": "#/$defs/RegistrationField" }
        },
        "fieldSources": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/RegistrationField" }
          }
        },
        "source": { "type": "string" },
        "confidence": { "type": "number" },
        "evidence": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RegistrationField": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "number" },
        "evidence": { "type": "string" }
      },
      "additionalProperties": false
    },
    "NetworkInfo": {
      "type": "object",
      "properties": {
        "cidr": { "type": "string" },
        "range": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "originAS": { "type": "string" },
        "country": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ResultMeta": {
      "type": "object",
      "required": ["elapsedMs"],
      "properties": {
        "elapsedMs": { "type": "integer" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "traceId": { "type": "string" },
        "pendingEnrichments": {
          "type": "array",
          "items": { "type": "string" }
        },
        "providers": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProviderTrace" }
        },
        "ai": { "$ref": "#/$defs/AITrace" }
      },
      "additionalProperties": false
    },
    "AITrace": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string" },
        "cached": { "type": "boolean" },
        "elapsedMs": { "type": "integer" },
        "attempts": { "type": "integer" },
        "applied": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reason": { "type": "string" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ProviderTrace": {
      "type": "object",
      "required": ["source", "status", "elapsedMs"],
      "properties": {
        "source": { "enum": ["rdap", "whois", "whoisWeb"] },
        "status": { "enum": ["ok", "error", "skipped"] },
        "server": { "type": "string" },
        "query": { "type": "string" },
        "statusCode": { "type": "integer" },
        "contentType": { "type": "string" },
        "bytes": { "type": "integer" },
        "elapsedMs": { "type": "integer" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Capabilities": {
      "type": "object",
      "required": ["api", "apiEndpoints", "apiIpAllowlist", "rdap", "whois", "whoisWeb", "customServers", "auth", "rateLimit", "icpAutoQuery", "enrichment"],
      "properties": {
        "api": { "type": "boolean" },
        "apiEndpoints": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "apiIpAllowlist": { "type": "boolean" },
        "rdap": { "type": "boolean" },
        "whois": { "type": "boolean" },
        "whoisWeb": { "type": "boolean" },
        "customServers": { "type": "boolean" },
        "auth": { "type": "string" },
        "rateLimit": { "type": "boolean" },
        "icpAutoQuery": { "type": "boolean" },
        "enrichment": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      },
      "additionalProperties": false
    },
    "DNSInfo": {
      "type": "object",
      "properties": {
        "a": {
          "type": "array",
          "items": { "$ref": "#/$defs/DNSAddress" }
        },
        "aaaa": {
          "type": "array",
          "items": { "$ref": "#/$defs/DNSAddress" }
        },
        "cname": { "type": "string" },
        "mx": {
          "type": "array",
          "items": { "$ref": "#/$defs/DNSMX" }
        },
        "ns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "registryNs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nsMismatch": { "type": "boolean" },
        "resolvers": {
          "type": "array",
          "items": { "$ref": "#/$defs/DNSResolverInfo" }
        },
        "elapsedMs": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "DNSVizInfo": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "PricingInfo": {
      "type": "object",
      "properties": {
        "register": { "type": "number" },
        "renew": { "type": "number" },
        "transfer": { "type": "number" },
          "currency": { "type": "string" },
          "provider": { "type": "string" },
          "source": { "type": "string" },
          "updatedAt": { "type": "string" },
          "registerOffer": { "$ref": "#/$defs/PricingOffer" },
          "renewOffer": { "$ref": "#/$defs/PricingOffer" },
          "transferOffer": { "$ref": "#/$defs/PricingOffer" }
        },
        "additionalProperties": false
      },
      "PricingOffer": {
        "type": "object",
        "properties": {
          "registrar": { "type": "string" },
          "website": { "type": "string", "format": "uri" },
          "logo": { "type": "string", "format": "uri" },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "priceCny": { "type": "number" }
        },
        "additionalProperties": false
      },
    "MozInfo": {
      "type": "object",
      "properties": {
        "domainAuthority": { "type": "integer" },
        "pageAuthority": { "type": "integer" },
        "spamScore": { "type": "integer" },
        "source": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DNSAddress": {
      "type": "object",
      "required": ["ip", "version"],
      "properties": {
        "ip": { "type": "string" },
        "version": { "enum": ["ipv4", "ipv6"] },
        "reverse": { "type": "string" },
        "source": { "enum": ["udp", "doh", "system"] },
        "resolver": { "type": "string" },
        "endpoint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DNSResolverInfo": {
      "type": "object",
      "required": ["source", "resolver"],
      "properties": {
        "source": { "enum": ["udp", "doh", "system"] },
        "resolver": { "type": "string" },
        "endpoint": { "type": "string" },
        "status": { "enum": ["ok", "empty", "error"] },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RawData": {
      "type": "object",
      "properties": {
        "whois": { "type": "string" },
        "rdap": { "type": "string" },
        "whoisWeb": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DNSMX": {
      "type": "object",
      "required": ["host", "pref"],
      "properties": {
        "host": { "type": "string" },
        "pref": { "type": "integer" }
      },
      "additionalProperties": false
    }
  }
}
